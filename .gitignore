# =============================================
# EduCenter - .gitignore
# =============================================

# === Build outputs ===
build/
dist/
*.war
*.ear

# === Compiled files ===
*.class
*.jar
!allowlibs/*.jar

# === NetBeans ===
nbproject/private/
nbproject/ant-deploy.xml
nbproject/build-impl.xml
nbbuild/
nbdist/

# === IDE ===
.idea/
*.iml
*.iws
*.ipr
.vscode/
.settings/
.classpath
.project

# === OS generated ===
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# === Logs ===
*.log
logs/

# === Temp files ===
*.tmp
*.bak
*.swp
*~

# === Uploaded files (runtime) ===
web/assets/avatars/*
web/assets/banners/*
web/assets/banners_course/*
web/assets/certs/*
web/uploads/
!web/assets/avatars/.gitkeep
!web/assets/banners/.gitkeep
!web/assets/banners_course/.gitkeep
!web/assets/certs/.gitkeep
